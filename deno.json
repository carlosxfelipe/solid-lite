{
  "fmt": {
    "useTabs": false,
    "lineWidth": 80,
    "indentWidth": 2,
    "singleQuote": false,
    "proseWrap": "preserve",
    "exclude": [
      "dist/",
      "solid/solid.js"
    ]
  },
  "lint": {
    "rules": {
      "tags": [
        "recommended"
      ]
    },
    "exclude": [
      "dist/",
      "solid/solid.js"
    ]
  },
  "tasks": {
    "stop": "lsof -ti:8000 | xargs kill -9 || true",
    "clean": "rm -rf dist",
    "build": "deno bundle --minify --outdir dist src/index.html && deno run -A scripts/copy_static.ts",
    "build:cdn": "deno run -A scripts/build_cdn.ts",
    "preview": "deno run -A scripts/server.ts",
    "dev": "deno task stop && deno task clean && deno run -A scripts/server.ts --dev",
    "start": "deno task stop && deno task clean && deno task build && deno task preview"
  },
  "compilerOptions": {
    "jsx": "react",
    "jsxFactory": "h",
    "jsxFragmentFactory": "Fragment",
    "strict": true,
    "lib": [
      "dom",
      "esnext",
      "deno.ns"
    ],
    "types": [
      "./solid/jsx.d.ts"
    ]
  },
  "imports": {
    "@std/collections": "jsr:@std/collections@^1.1.6",
    "@std/fmt": "jsr:@std/fmt@^1.0.9",
    "@std/async": "jsr:@std/async@^1.0.0",
    "@std/http/file-server": "jsr:@std/http@^1.0.25/file-server",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@std/testing": "jsr:@std/testing@^1.0.17",
    "@std/fs": "jsr:@std/fs@^1.0.0",
    "emit": "jsr:@deno/emit@^0.45.0",
    "@components/": "./src/components/",
    "@solid/": "./solid/",
    "@pages/": "./src/pages/",
    "@router/": "./src/router/",
    "@src/": "./src/",
    "@utils/": "./src/utils/"
  }
}
